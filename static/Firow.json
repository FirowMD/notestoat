    "editorLink.activeForeground": "#FFD369",
    "editorCodeLens.foreground": "#9AA0A8",
    "editorHoverWidget.background": "#393E46",
    "editorHoverWidget.foreground": "#EEEEEE",
    "editorHoverWidget.border": "#555B63",
    "editorSuggestWidget.background": "#393E46",
    "editorSuggestWidget.foreground": "#EEEEEE",
    "editorSuggestWidget.selectedBackground": "#4A5058",
    "editorSuggestWidget.highlightForeground": "#FFD369",
    "editorSuggestWidget.border": "#555B63",
    "editorWidget.background": "#393E46",
    "editorWidget.border": "#555B63",
    "editorOverviewRuler.border": "#00000000",
    "editorOverviewRuler.errorForeground": "#C9A24FCC",
    "editorOverviewRuler.warningForeground": "#FFD369CC",
    "editorOverviewRuler.infoForeground": "#EEEEEECC",
    "minimap.background": "#222831",
    "minimap.selectionHighlight": "#FFD36955",
    "minimap.findMatchHighlight": "#FFD36999",
    "scrollbarSlider.background": "#6A707A55",
